      "field_type": "text"
    },
    {
      "name": "Allow Block Break Exploits",
      "description": "Allow permanent block break exploits (vanilla mechanic). Enables bedrock, end portal frame, and other 'unbreakable' block removal using glitches. Paper patches this by default — enable to restore vanilla behavior",
      "env_variable": "ALLOW_BLOCK_BREAK_EXPLOITS",
      "default_value": "true",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|in:true,false",
      "field_type": "text"
    },
    {
      "name": "Allow Piston Duplication",
      "description": "Allow piston-based duplication (vanilla mechanic). Enables TNT and carpet duplication via pistons — widely used in farms and technical Minecraft. Paper patches this by default — enable to restore vanilla behavior",
