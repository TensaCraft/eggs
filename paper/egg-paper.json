    {
      "name": "Allow Headless Pistons",
      "description": "Allow headless piston exploit (vanilla mechanic). Used for TNT duplication farms and other redstone contraptions that rely on headless pistons. Paper patches this by default — enable to restore vanilla behavior",
      "env_variable": "ALLOW_HEADLESS_PISTONS",
